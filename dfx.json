{
  "canisters": {
    "polls_surveys_backend": {
      "main": "backend/polls_surveys_backend.mo",
      "type": "motoko",
      "args": "--enhanced-orthogonal-persistence"
    },
    "polls_surveys_frontend": {
      "source": ["frontend/dist"],
      "type": "assets",
      "workspace": "frontend"
    },
    "funding_hub": {
      "main": "canisters/funding_hub/main.mo",
      "type": "motoko"
    },
    "mytoken_ledger": {
      "type": "custom",
      "candid": "canisters/mytoken_ledger/ledger.did",
      "wasm": "canisters/mytoken_ledger/target/wasm32-unknown-unknown/release/ic-icrc1-ledger.wasm",
      "build": "cd canisters/mytoken_ledger && cargo build --target wasm32-unknown-unknown --release"
    }
  },
  "output_env_file": ".env",
  "defaults": {
    "build": {
      "packtool": "mops sources"
    }
  }
}
